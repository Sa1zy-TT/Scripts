--- ЛОГИКА ОПТИЧЕСКОГО ЗУМА ---
local currentZoomLevel = 1 

local function updateZoom()
    -- Рассчитываем угол обзора камеры (базовый FOV в роблоксе = 70)
    -- Чем выше кратность зума, тем меньше FOV (сильнее фокус на объекте)
    local targetFOV = 70 / currentZoomLevel
    camera.FieldOfView = targetFOV
    valLabel.Text = currentZoomLevel .. "x"
end

-- Кнопка ПЛЮС: приближает камеру к объектам
plusBtn.MouseButton1Click:Connect(function()
    if currentZoomLevel < 100 then
        if currentZoomLevel < 10 then
            currentZoomLevel = currentZoomLevel + 1 -- До 10х плавно по одному шагу
        else
            currentZoomLevel = currentZoomLevel + 10 -- После 10х шагами по 10
        end
        if currentZoomLevel > 100 then currentZoomLevel = 100 end
        updateZoom()
    end
end)

-- Кнопка МИНУС: отдаляет зум обратно
minusBtn.MouseButton1Click:Connect(function()
    if currentZoomLevel > 1 then
        if currentZoomLevel <= 10 then
            currentZoomLevel = currentZoomLevel - 1
        else
            currentZoomLevel = currentZoomLevel - 10
        end
        if currentZoomLevel < 1 then currentZoomLevel = 1 end
        updateZoom()
    end
end)
