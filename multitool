Instance.new("UICorner", switchBtn).CornerRadius = UDim.new(0, 8)

-- Кнопка ВКЛ / ВЫКЛ (Красная/Зеленая)
local toggleBtn = Instance.new("TextButton", mainFrame)
toggleBtn.Size = UDim2.new(1, -24, 0, 32)
toggleBtn.Position = UDim2.new(0, 12, 0, 105)
toggleBtn.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
toggleBtn.Text = "STATUS: OFF"
toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleBtn.Font = Enum.Font.GothamBold
toggleBtn.TextSize = 13
Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 8)

--- ЛОГИКА СУПЕР-ФУНКЦИЙ ---

local currentMode = "Fling" -- Может быть "Fling" или "Kill"
local isActive = false

-- Переключатель режимов
switchBtn.MouseButton1Click:Connect(function()
    if currentMode == "Fling" then
        currentMode = "Kill"
        modeLabel.Text = "MODE: TOUCH KILL"
        modeLabel.TextColor3 = Color3.fromRGB(255, 140, 0) -- Оранжевый для Килла
    else
        currentMode = "Fling"
        modeLabel.Text = "MODE: TOUCH FLING"
        modeLabel.TextColor3 = Color3.fromRGB(255, 255, 255) -- Белый для Флинга
    end
end)

-- Активация скрипта
toggleBtn.MouseButton1Click:Connect(function()
    isActive = not isActive
    if isActive then
        toggleBtn.Text = "STATUS: ON"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(50, 180, 80) -- Зеленый
    else
        toggleBtn.Text = "STATUS: OFF"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(220, 60, 60) -- Красный
    end
end)

-- Основной цикл проверки дистанции до игроков
runService.Heartbeat:Connect(function()
    if not isActive then return end
    
    local character = localPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    for _, targetPlayer in pairs(players:GetPlayers()) do
        if targetPlayer ~= localPlayer and targetPlayer.Character then
            local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
            
            if targetRoot then
                -- Считаем расстояние между тобой и другим челом
                local distance = (rootPart.Position - targetRoot.Position).Magnitude
                
                if distance < 4.5 then -- Дистанция касания
                    if currentMode == "Fling" then
                        -- РЕЖИМ ФЛИНГА: Раскручиваем физику на полную
                        rootPart.AssemblyLinearVelocity = Vector3.new(99999, 99999, 99999)
                    elseif currentMode == "Kill" then
                        -- РЕЖИМ КИЛЛА: Используем firetouchinterest, если в руке есть Tool
                        local tool = character:FindFirstChildOfClass("Tool")
                        if tool and tool:FindFirstChild("Handle") then
                            firetouchinterest(targetRoot, tool.Handle, 0)
                            firetouchinterest(targetRoot, tool.Handle, 1)
                        else
                            -- Если пустые руки, мощно вбиваем цель вниз
                            rootPart.AssemblyLinearVelocity = Vector3.new(0, -99999, 0)
                        end
                    end
                end
            end
        end
    end
end
