-- Кнопка ПЕРЕКЛЮЧЕНИЯ режимов (Синяя)
local switchBtn = Instance.new("TextButton", mainFrame)
switchBtn.Size = UDim2.new(1, -24, 0, 32)
switchBtn.Position = UDim2.new(0, 12, 0, 68)
switchBtn.BackgroundColor3 = Color3.fromRGB(50, 90, 220)
switchBtn.Text = "SWITCH MODE"
